# -----------------------------------------------------------------------------
# qb Framework - Installed Configuration File
#
# This file is generated during installation and allows users to find and
# use the qb framework with find_package(qb).
# -----------------------------------------------------------------------------

@PACKAGE_INIT@

# Set version information
set(QB_VERSION "@QB_FRAMEWORK_VERSION@")
set(QB_VERSION_MAJOR "@QB_FRAMEWORK_VERSION_MAJOR@")
set(QB_VERSION_MINOR "@QB_FRAMEWORK_VERSION_MINOR@")
set(QB_VERSION_PATCH "@QB_FRAMEWORK_VERSION_PATCH@")

# Compute the installation prefix relative to this file
get_filename_component(_IMPORT_PREFIX "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)

# Set include directories
set(QB_INCLUDE_DIRS "${_IMPORT_PREFIX}/include;${_IMPORT_PREFIX}/include/modules")

# Available components
set(_QB_AVAILABLE_COMPONENTS core io)

# Default to all components if none specified
if(NOT qb_FIND_COMPONENTS)
    set(qb_FIND_COMPONENTS ${_QB_AVAILABLE_COMPONENTS})
endif()

# Component dependency mapping
set(_QB_core_DEPENDS io)
set(_QB_io_DEPENDS "")

# Function to resolve component dependencies
function(_qb_resolve_component_deps component result_var)
    set(_deps ${_QB_${component}_DEPENDS})
    set(_all_deps ${_deps})
    
    foreach(_dep ${_deps})
        _qb_resolve_component_deps(${_dep} _recursive_deps)
        list(APPEND _all_deps ${_recursive_deps})
    endforeach()
    
    if(_all_deps)
        list(REMOVE_DUPLICATES _all_deps)
    endif()
    
    set(${result_var} ${_all_deps} PARENT_SCOPE)
endfunction()

# Process requested components and their dependencies
set(_QB_COMPONENTS_TO_LOAD)
foreach(_comp ${qb_FIND_COMPONENTS})
    list(APPEND _QB_COMPONENTS_TO_LOAD ${_comp})
    _qb_resolve_component_deps(${_comp} _comp_deps)
    list(APPEND _QB_COMPONENTS_TO_LOAD ${_comp_deps})
endforeach()

if(_QB_COMPONENTS_TO_LOAD)
    list(REMOVE_DUPLICATES _QB_COMPONENTS_TO_LOAD)
endif()

# Load component targets
foreach(_comp ${_QB_COMPONENTS_TO_LOAD})
    set(_targets_file "${CMAKE_CURRENT_LIST_DIR}/qb-${_comp}Targets.cmake")
    
    if(EXISTS "${_targets_file}")
        include("${_targets_file}")
        
        # Check if target exists
        if(TARGET qb::${_comp})
            set(QB_${_comp}_FOUND TRUE)
            set(qb_${_comp}_FOUND TRUE)
        else()
            set(QB_${_comp}_FOUND FALSE)
            set(qb_${_comp}_FOUND FALSE)
        endif()
    else()
        set(QB_${_comp}_FOUND FALSE)
        set(qb_${_comp}_FOUND FALSE)
        
        if(qb_FIND_REQUIRED_${_comp})
            message(FATAL_ERROR "Required qb component '${_comp}' not found")
        endif()
    endif()
endforeach()

# Set convenience variables
set(QB_LIBRARIES)
set(QB_TARGETS)

if(TARGET qb::core)
    list(APPEND QB_LIBRARIES qb::core)
    list(APPEND QB_TARGETS qb::core)
    set(QB_CORE_TARGET qb::core)
endif()

if(TARGET qb::io)
    list(APPEND QB_LIBRARIES qb::io)
    list(APPEND QB_TARGETS qb::io)
    set(QB_IO_TARGET qb::io)
endif()

# Check if all required components were found
set(_QB_REQUIRED_COMPONENTS_FOUND TRUE)
foreach(_comp ${qb_FIND_COMPONENTS})
    if(qb_FIND_REQUIRED_${_comp} AND NOT QB_${_comp}_FOUND)
        set(_QB_REQUIRED_COMPONENTS_FOUND FALSE)
        break()
    endif()
endforeach()

# Set main found variable
if(_QB_REQUIRED_COMPONENTS_FOUND)
    set(QB_FOUND TRUE)
    set(qb_FOUND TRUE)
else()
    set(QB_FOUND FALSE)
    set(qb_FOUND FALSE)
endif()

# Feature information (set during build)
set(QB_HAS_SSL @QB_HAS_SSL@)
set(QB_HAS_COMPRESSION @QB_HAS_COMPRESSION@)
set(QB_HAS_ARGON2 @QB_HAS_ARGON2@)

# Clean up internal variables
unset(_IMPORT_PREFIX)
unset(_QB_AVAILABLE_COMPONENTS)
unset(_QB_COMPONENTS_TO_LOAD)
unset(_QB_REQUIRED_COMPONENTS_FOUND) 